# Auth0 — v4 SDK uses these variable names
AUTH0_SECRET=                          # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.auth0.com    # no https:// prefix
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://vigil.api

# Auth0 Connected Account connection names
GOOGLE_CONNECTION_NAME=google-oauth2
GITHUB_CONNECTION_NAME=github

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vigil

# LLM (Groq)
GROQ_API_KEY=
# Primary model: moonshotai/kimi-k2-instruct
# Fallback:      meta-llama/llama-4-scout-17b-16e-instruct

# Cron auth (generate a random secret)
CRON_SECRET=
